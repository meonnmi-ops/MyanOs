# MyanOS Web OS v4.3.0 — .gitignore

# Security (NEVER commit these)
.myanos_api_key
.myanos_pw_hash
.myanos_password
.myanos.pid
.myanos.log

# Package manager database
.myan_db.json

# Installed packages (local)
installed/

# Built packages (regenerated by build_packages.py)
dist/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build temp
_build_data/
_build_tmp/
_build_checksum.sha256
